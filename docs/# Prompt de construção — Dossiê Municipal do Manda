## Estrutura do banco de dados (Supabase / PostgreSQL)

```sql
-- Municípios
municipios (
  id uuid PK,
  nome text NOT NULL,
  regiao text,
  populacao int,
  created_at timestamptz
)

-- Usuários (extensão da auth.users do Supabase)
perfis (
  id uuid PK references auth.users,
  nome text,
  role text CHECK (role IN ('deputado', 'lideranca', 'assessoria')),
  municipio_id uuid references municipios -- nulo para deputado e assessoria
)

-- Contatos
contatos (
  id uuid PK,
  municipio_id uuid references municipios,
  enviado_por uuid references perfis,
  nome text NOT NULL,
  telefone text,
  email text,
  tags text[],
  status text CHECK (status IN ('pendente', 'aprovado', 'rejeitado')),
  consentiu boolean DEFAULT false,
  created_at timestamptz
)

-- Políticos aliados
politicos (
  id uuid PK,
  municipio_id uuid references municipios,
  cargo text, -- 'prefeito', 'vice', 'vereador'
  nome text NOT NULL,
  partido text,
  telefone text,
  aliado boolean DEFAULT true
)

-- Emendas parlamentares
emendas (
  id uuid PK,
  municipio_id uuid references municipios,
  titulo text NOT NULL,
  valor numeric,
  area text, -- 'saúde', 'educação', 'infraestrutura', etc.
  status text CHECK (status IN ('proposta', 'aprovada', 'empenhada', 'executada', 'bloqueada')),
  ano int,
  observacoes text
)

-- Obras e projetos
obras (
  id uuid PK,
  municipio_id uuid references municipios,
  titulo text NOT NULL,
  descricao text,
  status text CHECK (status IN ('planejada', 'em_andamento', 'concluida', 'paralisada')),
  emenda_id uuid references emendas,
  previsao_conclusao date
)

-- Agenda / eventos
eventos (
  id uuid PK,
  municipio_id uuid references municipios,
  titulo text NOT NULL,
  descricao text,
  data_hora timestamptz,
  local text,
  tipo text -- 'visita', 'reunião', 'inauguração', etc.
)

-- Notas da assessoria
notas (
  id uuid PK,
  municipio_id uuid references municipios,
  autor_id uuid references perfis,
  conteudo text NOT NULL,
  created_at timestamptz
)

-- Fotos e mídia
midias (
  id uuid PK,
  municipio_id uuid references municipios,
  url text NOT NULL, -- URL do Supabase Storage
  legenda text,
  tipo text CHECK (tipo IN ('foto', 'documento')),
  created_at timestamptz
)

-- Pendências políticas (situações em aberto)
pendencias (
  id uuid PK,
  municipio_id uuid references municipios,
  titulo text NOT NULL,
  descricao text,
  tipo text, -- 'demanda', 'conflito', 'compromisso', 'follow-up'
  prioridade text CHECK (prioridade IN ('baixa', 'media', 'alta', 'urgente')),
  status text CHECK (status IN ('aberta', 'em_tratativa', 'resolvida')),
  responsavel_id uuid references perfis,
  prazo date,
  created_at timestamptz,
  updated_at timestamptz
)
```

**Row Level Security (RLS) no Supabase:**
- `lideranca`: SELECT/INSERT apenas em registros onde `municipio_id = perfis.municipio_id`
- `assessoria`: SELECT/INSERT/UPDATE/DELETE em tudo
- `deputado`: SELECT em tudo, sem escrita

